# Server
NODE_ENV=development
PORT=5000

# Database (Sequelize — tên biến cố định trong code)
# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fashion_ecommerce
DB_USER=root
DB_PASSWORD=Sa@123

# --- Railway MySQL (tab Variables) → ánh xạ sang DB_* ---
# MYSQLDATABASE hoặc MYSQL_DATABASE  →  DB_NAME
# MYSQLHOST                           →  DB_HOST   (xem lưu ý bên dưới)
# MYSQLPORT                           →  DB_PORT
# MYSQLUSER                           →  DB_USER
# MYSQLPASSWORD                       →  DB_PASSWORD
# KHÔNG dùng MYSQL_ROOT_PASSWORD trừ khi bạn cố ý kết nối bằng user root.
#
# API chạy trên Render / máy ngoài Railway: cần host PORT công khai.
# Mở giá trị MYSQL_PUBLIC_URL (mysql://USER:PASS@HOST:PORT/DB) và lấy HOST, PORT;
# hoặc bật Public networking trên Railway rồi dùng public host/port tương ứng.
# MYSQL_URL thường là chuỗi nội bộ (chỉ khi app cùng project Railway).

# JWT
JWT_ACCESS_SECRET=your_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mailjet
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_FROM_EMAIL=verified-sender@yourdomain.com
MAILJET_FROM_NAME=LuxeMode

# OTP
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_DAY_PER_EMAIL=5

# Client URL
CLIENT_URL=http://localhost:5173

# Shipping (USD): free when cart subtotal >= FREE_SHIPPING_MIN; otherwise STANDARD_SHIPPING_FEE applies
FREE_SHIPPING_MIN=20
STANDARD_SHIPPING_FEE=5.99
